diff --git a/meta-oe/recipes-kernel/crash-memory-driver/crash-memory-driver_8.0.6.bb b/meta-oe/recipes-kernel/crash-memory-driver/crash-memory-driver_8.0.6.bb
new file mode 100644
index 0000000000..81573fb049
--- /dev/null
+++ b/meta-oe/recipes-kernel/crash-memory-driver/crash-memory-driver_8.0.6.bb
@@ -0,0 +1,42 @@
+DESCRIPTION = "Once installed, the /dev/crash driver will be used by default for live system crash sessions."
+SECTION = "devel"
+SUMMARY = "/dev/crash driver"
+HOMEPAGE = "https://github.com/crash-utility/crash/tree/master/memory_driver"
+RECIPE_MAINTAINER = "Robert Berger <Robert.Berger@ReliableEmbeddedSystems.com>"
+LICENSE = "GPL-2.0-only"
+LIC_FILES_CHKSUM = "file://${COMMON_LICENSE_DIR}/GPL-2.0-only;md5=801f80980d171dd6425610833a22dbe6"
+
+inherit module
+
+SRCREV = "f13853cef53f5c5463a51021edbc81977e2b1405"
+SRC_URI = "git://github.com/crash-utility/crash;protocol=https;branch=master;subpath=memory_driver \
+           file://0001-hacked-Makefilefor-module.bbclass.patch \
+           file://0002-add-sparse-support.patch"
+PV = "8.0.6+git${SRCPV}"
+
+#S = "${WORKDIR}/git"
+#UNPACKDIR = "${S}"
+S = "${UNPACKDIR}"
+
+do_compile:prepend() {
+  mv memory_driver/* .
+}
+
+
+# The inherit of module.bbclass will automatically name module packages with
+# "kernel-module-" prefix as required by the oe-core build environment.
+
+RPROVIDES:${PN} += "kernel-module-crash-memory-driver"
+
+# to local.conf add:
+#    to add the kernel module to the rootfs:
+# MACHINE_ESSENTIAL_EXTRA_RDEPENDS += "kernel-module-crash-memory-driver"
+#    to autoload it:
+# KERNEL_MODULE_AUTOLOAD += "crash"
+
+# in case we use sparse in the kernel module makefile
+DEPENDS = "sparse-native"
+
+ERROR_QA:remove = "buildpaths"
+WARN_QA:append = " buildpaths"
+
